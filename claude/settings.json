{
  "permissions": {
    "allow": [
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh repo view:*)",
      "Bash(git add:*)"
    ]
  },
  "model": "claude-opus-4-6[1m]",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd ~/dotfiles && STATUS=$(git status --porcelain) && [ -n \"$STATUS\" ] && echo '{\"systemMessage\": \"Dotfiles have uncommitted changes: '\"$(echo $STATUS | tr '\\n' ' ')\"'\"}' || echo '{\"systemMessage\": \"Dotfiles up to date.\"}'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "agentic-audit@agentic-audit": true,
    "agentic-tests@agentic-tests": true,
    "superpowers@superpowers-dev": true,
    "codex@openai-codex": true,
    "harness-system@harness-system": true
  },
  "extraKnownMarketplaces": {
    "agentic-audit": {
      "source": {
        "source": "github",
        "repo": "fliingelephant/agentic-audit"
      }
    },
    "agentic-tests": {
      "source": {
        "source": "github",
        "repo": "GiggleLiu/agentic-tests"
      }
    },
    "superpowers-dev": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "harness-system": {
      "source": {
        "source": "directory",
        "path": "/Users/zhou/workflow/harness-system"
      },
      "autoUpdate": true
    }
  },
  "effortLevel": "xhigh",
  "autoMemoryEnabled": false,
  "autoDreamEnabled": true,
  "voiceEnabled": true
}
