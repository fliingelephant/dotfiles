{
  "permissions": {
    "allow": [
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh repo view:*)",
      "Bash(git add:*)"
    ]
  },
  "model": "claude-fable-5[1m]",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd ~/dotfiles && STATUS=$(git status --porcelain) && [ -n \"$STATUS\" ] && echo '{\"systemMessage\": \"Dotfiles have uncommitted changes: '\"$(echo $STATUS | tr '\\n' ' ')\"'\"}' || echo '{\"systemMessage\": \"Dotfiles up to date.\"}'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "agentic-audit@agentic-audit": false,
    "agentic-tests@agentic-tests": true,
    "codex@openai-codex": true,
    "superpowers@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "mcp-server-dev@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "agentic-audit": {
      "source": {
        "source": "github",
        "repo": "fliingelephant/agentic-audit"
      }
    },
    "agentic-tests": {
      "source": {
        "source": "github",
        "repo": "GiggleLiu/agentic-tests"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "effortLevel": "xhigh",
  "autoCompactWindow": 400000,
  "tui": "fullscreen",
  "autoMemoryEnabled": false,
  "autoDreamEnabled": true,
  "skipWorkflowUsageWarning": true,
  "theme": "auto",
  "voiceEnabled": true
}
